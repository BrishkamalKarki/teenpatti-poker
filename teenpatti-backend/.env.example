# Copy to .env for local runs (uvicorn/python-dotenv aren't wired to auto-load
# this — either `export $(cat .env | xargs)` before running, or set these in
# your host's dashboard when deploying).

# Comma-separated list of frontend origins allowed to connect, or "*" for any.
CORS_ORIGINS=*

# Most hosts (Render, Railway, Fly) inject PORT for you automatically.
PORT=4000
