# The frontend origins allowed to connect. "*" is fine locally; set it to your
# real URL before sharing the game with anyone.
#   CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Optional: verify players' transactions against the real blockchain.
# ---------------------------------------------------------------------------
# With both of these set, the server checks that every claimed entry fee and
# every claimed bet really exists on-chain, succeeded, went to the contract,
# came from that player's wallet, and carried at least that much ETH.
#
# Leave them blank and the server trusts what the browser tells it — fine for
# playing at home, worth turning on for anything public. See app/chain.py.
ETH_RPC_URL=
CONTRACT_ADDRESS=
