# ---------------------------------------------------------------------------
# 1. The smart contract
# ---------------------------------------------------------------------------
# The address TeenPattiGame.sol was deployed to. This MUST be on the same
# network your players' wallets are connected to — a Sepolia address with
# MetaMask on localhost (or the reverse) is the single most common mistake,
# and the app will tell you so on connect rather than failing cryptically.
#
#   ./scripts/sync-abi.sh                          # after any contract change
#   forge script script/Deploy.s.sol --rpc-url ... --private-key ... --broadcast
VITE_CONTRACT_ADDRESS=

# ---------------------------------------------------------------------------
# 2. The game server
# ---------------------------------------------------------------------------
# Local:      http://localhost:4000
# Deployed:   https://your-backend.onrender.com
VITE_SERVER_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# 3. Optional: a read-only RPC endpoint
# ---------------------------------------------------------------------------
# Lets the Blockchain panel read the chain (pot, receipts, gas) even before a
# wallet is connected. Leave it blank to use the wallet's own connection.
#   Local Anvil:  http://127.0.0.1:8545
#   Sepolia:      https://ethereum-sepolia-rpc.publicnode.com
VITE_RPC_URL=
