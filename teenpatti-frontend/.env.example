# Copy this file to .env and fill in the values from your Foundry deploy.

# Address TeenPattiRoom.sol was deployed to (e.g. `forge create` output on Anvil)
VITE_TEENPATTI_CONTRACT_ADDRESS=

# Anvil defaults — only change these if you're running a different chain/port
VITE_CHAIN_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337

# Socket.io backend (your Node server running teenPattiEngine.js)
VITE_SOCKET_URL=http://localhost:4000
